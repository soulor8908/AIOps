# Environment variables for AIOps Console
# Copy to .env and fill in your values
#
# 完整变量清单见 backend/app/core/config.py，本文件按分组列出生产部署常用项。
# 生产环境（ENVIRONMENT=production/staging）必须显式设置 JWT_SECRET 与 OPENAI_API_KEY，
# 否则启动 fail-fast（config.py 的 _validate_secret_key / _validate_required_prod_vars）。

# ===================== 基础 =====================
DEBUG=true
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# ===================== 数据库 / 缓存 =====================
DATABASE_URL=postgresql+asyncpg://aiops:aiops@localhost:5432/aiops
REDIS_URL=redis://localhost:6379
# 连接池配置（P0-11）：pool_recycle 主动回收长连接避开 LB idle 超时
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=10.0
# PG statement_timeout 毫秒（P0-22）：慢查询超此值被 PG 主动 kill，仅 PG 生效
DB_STATEMENT_TIMEOUT_MS=30000

# ===================== 安全 — JWT =====================
# JWT_SECRET 为真源，SECRET_KEY 为兼容别名（生产必须 ≥32 字节强密钥）
JWT_SECRET=change-me-in-production
SECRET_KEY=change-me-in-production
JWT_EXPIRE_HOURS=24
# 兼容旧字段：显式设置则覆盖 hours 计算
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=7
# CORS
# 仅当前端与后端部署在不同 Origin（域名/端口）时才需要配置。
# 同源部署（dev: Vite proxy /prod: nginx 反代 /api）时无需跨域，可留空使用默认值。
# 默认放行 localhost 与 127.0.0.1 的常见 dev 端口，覆盖直连后端场景。
# 禁止包含 "*"（security.spec.md§4）
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]
# token 黑名单开关（P0-1）：默认 True，Redis 不可用时降级放行
TOKEN_BLACKLIST_ENABLED=true
# 登录失败锁定（P0-2）：连续失败 N 次锁定 M 分钟
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
# fire-and-forget task 背压上限（P0-10）：0=不限制，生产建议 50~200
TASK_REGISTRY_MAX_CONCURRENCY=0

# ===================== LLM =====================
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# LLMClient 单例缓存上限（P0-21）
LLM_CLIENT_CACHE_MAX_SIZE=32
LLM_CLIENT_MAX_CONNECTIONS=100
LLM_CLIENT_MAX_KEEPALIVE_CONNECTIONS=20
# LLM 流式逐 chunk 超时秒数（P0-14）：两个 chunk 间隔超此值视为 provider 卡死
LLM_STREAM_CHUNK_TIMEOUT_SECONDS=30

# ===================== Agent =====================
# autonomous loop worker（P0-2）：默认关闭，生产按需启用
AGENT_SCHEDULER_ENABLED=false
AGENT_SCHEDULER_INTERVAL_SECONDS=60
AGENT_SCHEDULER_CONCURRENCY=5
AGENT_SCHEDULER_TIMEOUT_SECONDS=300
AGENT_SCHEDULER_LEASE_SECONDS=600
# 单次执行最大轮次（B1）：默认 10，长任务 Agent 可调到 50
AGENT_MAX_TURNS=10
# HTTP 请求级整体超时秒数（P0-20）：超时抛 504
AGENT_EXECUTE_TIMEOUT_SECONDS=180
# context 压缩阈值 token 数（B4）
AGENT_CONTEXT_COMPRESS_TOKENS=4000
# self-eval 采样次数（B3）：默认 3 次取均值抑制 ±0.1 噪声
AGENT_SELF_EVAL_SAMPLES=3

# ---- Agent 记忆层（P1-4/P1-5）----
AGENT_MEMORY_ENABLED=false
AGENT_MEMORY_TOP_K=3
AGENT_QUERY_REWRITE_ENABLED=false
AGENT_QUERY_REWRITE_N_VARIANTS=2
AGENT_QUERY_REWRITE_HYDE=true

# ---- 成本感知模型路由（P1-6）----
AGENT_COST_ROUTING_ENABLED=false
AGENT_COST_CHEAP_MODEL_ALIAS=cheap
AGENT_COST_PREMIUM_MODEL_ALIAS=premium
AGENT_COST_TOKEN_BUDGET=0
AGENT_COST_BUDGET_WINDOW_SECONDS=3600
# 多副本共享预算（A1）：K8s HPA 多副本必须启用，否则熔断永远不触发
AGENT_COST_BUDGET_REDIS_ENABLED=false

# ---- code 工具执行（A2，脚枪，默认关）----
AGENT_CODE_TOOL_ENABLED=false

# ---- 失败模式聚类（P2-8）----
AGENT_FAILURE_CLUSTERING_ENABLED=false
AGENT_FAILURE_CLUSTER_DISTANCE_THRESHOLD=0.3
AGENT_FAILURE_CLUSTER_DLQ_PATH=

# ---- Planning + Reflection（P2-10）----
AGENT_PLANNING_ENABLED=false
AGENT_REFLECTION_ENABLED=false

# ===================== Online Eval（P0-3 / C5）=====================
# 生产采样率。0.0=关闭（默认），0~1 概率，每次 execute_agent 成功后异步记录样本
ONLINE_EVAL_SAMPLE_RATE=0.0
# 分层采样 boost 倍数：高优先级样本采样率放大
ONLINE_EVAL_SAMPLE_RATE_BOOST=5.0
# priority 启发式阈值：输入字符数超此值则 priority +1
ONLINE_EVAL_PRIORITY_INPUT_LEN_THRESHOLD=200

# ===================== Lifespan / 优雅关闭 =====================
# shutdown 整体超时秒数（P0-12）：K8s terminationGracePeriodSeconds 应 >= 此值 + 10s
LIFESPAN_SHUTDOWN_TIMEOUT_SECONDS=20

# ===================== Frontend =====================
# 默认使用相对路径 /api/v1：
# - dev：vite.config.ts 的 server.proxy 把 /api 转发到 http://localhost:8000（同源，无 CORS）
# - prod：ops/nginx.conf 的 location /api/ 反代到 aiops-backend（同源，无 CORS）
# 仅当前端独立部署到与后端不同 Origin 时，才需要显式设为后端绝对地址
# VITE_API_BASE_URL=/api/v1
