# Environment variables for AIOps Console
# Copy to .env and fill in your values

# Backend
DEBUG=true
APP_VERSION=0.1.0
DATABASE_URL=postgresql+asyncpg://aiops:aiops@localhost:5432/aiops
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
# 仅当前端与后端部署在不同 Origin（域名/端口）时才需要配置。
# 同源部署（dev: Vite proxy /prod: nginx 反代 /api）时无需跨域，可留空使用默认值。
# 默认放行 localhost 与 127.0.0.1 的常见 dev 端口，覆盖直连后端场景。
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]

# LLM
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
# 默认使用相对路径 /api/v1：
# - dev：vite.config.ts 的 server.proxy 把 /api 转发到 http://localhost:8000（同源，无 CORS）
# - prod：ops/nginx.conf 的 location /api/ 反代到 aiops-backend（同源，无 CORS）
# 仅当前端独立部署到与后端不同 Origin 时，才需要显式设为后端绝对地址
# VITE_API_BASE_URL=/api/v1
