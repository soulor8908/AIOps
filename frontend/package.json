{
  "name": "aiops-console-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "gen:api": "openapi-typescript ../specs/openapi.yaml -o src/shared/api/types.generated.ts"
  },
  "dependencies": {
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-istanbul": "^2.1.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.5.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^8.0.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.10"
  }
}
